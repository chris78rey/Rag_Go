# ============================================
# Variables Coolify (obligatorias)
# ============================================
CLIENT_ID=mi-app-rag
DOMAIN=rag.mi-dominio.com

# ============================================
# OpenRouter (obligatorio)
# ============================================
OPENROUTER_API_KEY=sk-or-v1-TU-API-KEY

# ============================================
# Seguridad (obligatorio - usa una clave larga)
# ============================================
JWT_SECRET=cambia-esto-por-una-clave-larga-y-segura

# ============================================
# Base de datos (obligatorio - contraseña PostgreSQL)
# ============================================
DB_PASSWORD=una-contraseña-fuerte-para-postgres

# ============================================
# Opcionales (con defaults recomendados)
# ============================================
OPENROUTER_MODEL=openai/gpt-4o-mini
EMBEDDING_MODEL=openai/text-embedding-3-large
QDRANT_COLLECTION=semantic_docs
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=10
LOG_LEVEL=info

# ============================================
# Para subir a Coolify:
# 1. Crea un "New Service" tipo "Docker Compose"
# 2. Copia este .env y docker-compose_vps.yml
# 3. Configura CLIENT_ID y DOMAIN según tu dominio
# 4. Asegúrate que la red "coolify" exista en tu VPS
# ============================================
